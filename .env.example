# Server listen address (env var)
# Binds to all interfaces by default. Set to Tailscale IP in production
# so the server is only reachable via the VPN tunnel.
BIND_ADDR=:8080

# ─── config.json (auto-generated on first run) ──────────────────

# Upload storage directory
# "storagePath": "uploads"

# MediaRecorder chunk duration in milliseconds
# "chunkDurationMs": 500

# Video bitrate in bits per second (5 Mbps default)
# "videoBitrate": 5000000

# Maximum webcam resolution
# "maxWidth": 1920
# "maxHeight": 1080

# Dashboard credentials (change these immediately)
# "adminUser": "admin"
# "adminPass": "admin"

# Participant info form fields
# "infoFields": ["Name", "Age", "Notes"]

# ─── nginx reverse proxy (VPS only) ────────────────────────────

# Domain: set in deploy/nginx.conf → server_name directive
# Tailscale IP: set in deploy/nginx.conf → proxy_pass directive
# TLS: certbot handles Let's Encrypt automatically
